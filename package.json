{
  "name": "formpilot",
  "version": "0.1.0",
  "description": "Bank form-filling web app for Nigerian banks. Officers send guided links; customers fill and download a print-ready PDF — all client-side.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx serve . -p 5173",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint": "echo \"Add eslint in Sprint 7\" && exit 0",
    "format": "echo \"Add prettier in Sprint 7\" && exit 0"
  },
  "keywords": ["bank", "forms", "pdf", "nigeria", "fintech"],
  "author": "Paul Ekwem",
  "license": "UNLICENSED",
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "serve": "^14.2.4"
  }
}

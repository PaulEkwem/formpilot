# FormPilot environment variables.
# Copy to .env.local for local development.
# Production values live in Vercel project settings.
#
# NOTE: Public Supabase URL and anon key live in src/config/env.js
# (they are designed to be public — security lives in RLS policies).
# Only secrets belong here.

# Supabase Edge Functions (server-side only)
BREVO_API_KEY=xkeysib-...
SENDER_EMAIL=hello@formpilot.app

# Sentry (optional — only if doing source-map uploads)
SENTRY_AUTH_TOKEN=
